# 默认用户（scope 只写包名时生效）；空=全部
ALLOWED_USERS=0

# 发现进程轮询秒
POLL_SEC=3

# connect 探针
ENABLE_CONN=1

# 临终探针（部分机 tgkill 乱码，默认关）
ENABLE_DEATH=0

# 噪音路径
LOG_NOISE=0

PROBE_PREFIX=es_
MAX_EVENTS=500000

# 路径结果达到 512KB 后按相同结果聚合 count
MAX_RESULT_BYTES=524288

# 每个软件最多保留会话数
MAX_SESSIONS_PER_APP=3

# daemon.log 单文件上限，超过后轮转为 daemon.log.1
MAX_DAEMON_LOG_BYTES=524288
