#!/sbin/sh
# Magisk / KernelSU 通用安装器
umask 022
OUTFD=$2
ZIPFILE=$3

ui_print() {
  if [ -n "$OUTFD" ] && [ -e /proc/self/fd/$OUTFD ]; then
    echo "ui_print $1" > /proc/self/fd/$OUTFD
    echo "ui_print" > /proc/self/fd/$OUTFD
  else
    echo "$1"
  fi
}

install_ksu() {
  ui_print "- KernelSU / 兼容安装"
  # 优先 modules_update，否则直接 modules
  if [ -d /data/adb/modules_update ]; then
    MODPATH="/data/adb/modules_update/ebpf_stats"
  else
    MODPATH="/data/adb/modules/ebpf_stats"
  fi
  rm -rf "$MODPATH"
  mkdir -p "$MODPATH"
  unzip -o "$ZIPFILE" -x 'META-INF/*' -d "$MODPATH" >&2
  TMPDIR="${TMPDIR:-/dev/tmp}"
  mkdir -p "$TMPDIR"
  export MODPATH TMPDIR
  if [ -f "$MODPATH/customize.sh" ]; then
    . "$MODPATH/customize.sh"
  fi
  # 若装到 modules_update，标记
  if [ -d /data/adb/modules_update/ebpf_stats ] && [ ! -d /data/adb/modules/ebpf_stats ]; then
    :
  fi
  ui_print "- 完成，请重启"
  exit 0
}

if [ -f /data/adb/magisk/util_functions.sh ]; then
  . /data/adb/magisk/util_functions.sh
  [ "${MAGISK_VER_CODE:-0}" -lt 20400 ] && {
    ui_print "需要 Magisk 20.4+"
    exit 1
  }
  install_module
  exit 0
fi

# KernelSU / APatch / 其它
if [ -d /data/adb/ksu ] || [ -d /data/adb/modules ] || [ -f /data/adb/ksud ]; then
  install_ksu
fi

ui_print "未检测到 Magisk/KSU，无法安装"
exit 1
